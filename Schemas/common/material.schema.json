{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Material Assignment Definitions",
  "description": "UE5.5.4 材质槽位分配结构定义。用于描述 assign_material 写操作的输入和反馈。当前为 MVP Phase 2 能力。",
  "$defs": {
    "material_slot_assignment": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "component_name": {
          "type": "string",
          "description": "目标组件名称，例如 TruckMesh"
        },
        "slot_name": {
          "type": "string",
          "description": "材质槽位名称，例如 Body / Glass / Wheel"
        },
        "material_path": {
          "type": "string",
          "description": "材质资产路径，例如 /Game/Materials/M_Truck_Rust"
        }
      }
    },
    "material_readback": {
      "type": "object",
      "additionalProperties": false,
      "required": ["slot_index", "material_path", "material_name"],
      "properties": {
        "slot_index": {
          "type": "integer",
          "minimum": 0,
          "description": "材质槽位索引"
        },
        "material_path": {
          "$ref": "primitives.schema.json#/$defs/path_string",
          "description": "读回到的材质资产路径，例如 /Engine/EngineMaterials/DefaultMaterial.DefaultMaterial"
        },
        "material_name": {
          "$ref": "primitives.schema.json#/$defs/non_empty_string",
          "description": "材质显示名称，例如 DefaultMaterial"
        }
      }
    }
  }
}
